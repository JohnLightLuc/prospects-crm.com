# ============================================
#   ProSpect CRM — Variables d'environnement
# ============================================

# Serveur
PORT=3000
NODE_ENV=production

# Base de données PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=prospect_crm
DB_USER=postgres
DB_PASSWORD=votre_mot_de_passe_ici

# JWT (générez une clé aléatoire forte : openssl rand -base64 64)
JWT_SECRET=changez_cette_cle_secrete_en_production
JWT_EXPIRES_IN=7d

# Email (SMTP — exemple Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre@email.com
SMTP_PASS=votre_mot_de_passe_app
EMAIL_FROM=ProSpect CRM <votre@email.com>

# URL du frontend (pour CORS)
FRONTEND_URL=http://localhost:8080
